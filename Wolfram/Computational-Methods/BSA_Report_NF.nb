  ";"}], "\n", 
 RowBox[{
  RowBox[{"Eq0", " ", "=", " ", 
   RowBox[{"Thread", "[", 
    RowBox[{
     RowBox[{"D", "[", 
      RowBox[{"X", ",", " ", "t"}], "]"}], " ", "==", " ", 
     RowBox[{"A0", ".", "X"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Eq1", " ", "=", " ", 
   RowBox[{"Thread", "[", 
    RowBox[{
     RowBox[{"D", "[", 
      RowBox[{"X", ",", " ", "t"}], "]"}], " ", "==", " ", 
     RowBox[{"A1", ".", "X"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Sol0", " ", "=", " ", 
   RowBox[{"X", " ", "/.", " ", 
    RowBox[{
     RowBox[{"DSolve", "[", 
      RowBox[{
       RowBox[{"Union", "[", 
        RowBox[{"Eq0", ",", " ", "InX"}], "]"}], ",", " ", "X", ",", " ", 
       "t"}], "]"}], "[", 
     RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
