  RowBox[{"\<\"X(\[Mu]) = \"\>", "\[InvisibleSpace]", 
   RowBox[{
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"-", 
       FractionBox["x", "\[Mu]"]}]], " ", "n", " ", "\[Pi]", " ", "\[Mu]"}], 
    "+", 
    RowBox[{"n", " ", "\[Pi]", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "1"}], "+", "x"}], ")"}], " ", "\[Mu]", " ", 
     RowBox[{"Cos", "[", 
      RowBox[{"n", " ", "\[Pi]", " ", "x"}], "]"}]}], "-", 
    RowBox[{
     FractionBox["1", "2"], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "2"}], "+", 
       RowBox[{"2", " ", "\[Mu]"}], "+", 
