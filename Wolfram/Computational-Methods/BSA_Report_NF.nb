Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"DD", "[", 
    RowBox[{"n_", ",", " ", "M_"}], "]"}], " ", ":=", " ", 
   RowBox[{"PolynomialGCD", " ", "@@", " ", 
    RowBox[{"Flatten", "[", 
     RowBox[{"Minors", "[", 
      RowBox[{"M", ",", " ", "n"}], "]"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"F", "[", 
    RowBox[{"n_", ",", " ", "M_"}], "]"}], "  ", ":=", " ", 
   RowBox[{"Factor", "[", 
    RowBox[{"Expand", "[", 
     RowBox[{
      RowBox[{"DD", "[", 
       RowBox[{"n", ",", " ", "M"}], "]"}], " ", "/", " ", 
      RowBox[{"DD", "[", 
       RowBox[{
        RowBox[{"n", " ", "-", " ", "1"}], ",", " ", "M"}], "]"}]}], "]"}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"S0", " ", "=", " ", 
   RowBox[{"DiagonalMatrix", "[", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"F", "[", 
       RowBox[{"k", ",", " ", 
        RowBox[{"B", " ", "/.", " ", 
         RowBox[{"a", " ", "->", " ", "0"}]}]}], "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"k", ",", " ", "4", ",", " ", "1", ",", " ", 
        RowBox[{"-", "1"}]}], "}"}]}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"S1", " ", "=", " ", 
   RowBox[{"DiagonalMatrix", "[", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"F", "[", 
       RowBox[{"k", ",", " ", 
        RowBox[{"B", " ", "/.", " ", 
         RowBox[{"a", " ", "->", " ", "1"}]}]}], "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"k", ",", " ", "4", ",", " ", "1", ",", " ", 
        RowBox[{"-", "1"}]}], "}"}]}], "]"}], "]"}]}], ";"}]}], "Code",
