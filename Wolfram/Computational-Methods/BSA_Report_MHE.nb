Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ComputeA1", "[", 
    RowBox[{"\[Delta]_", ",", " ", "\[Epsilon]_", ",", " ", "n_"}], "]"}], 
   " ", ":=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"i", " ", "==", " ", "j"}], ",", " ", 
       RowBox[{"\[Delta]", " ", "-", " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"i", " ", "-", " ", "1"}], ")"}], "^", "2"}]}], ",", " ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"i", " ", "==", " ", "1"}], " ", "&&", " ", 
          RowBox[{"j", " ", "==", " ", "2"}]}], ",", " ", "\[Epsilon]", ",", 
         " ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"i", " ", "-", " ", "j"}], "]"}], " ", "==", " ", "1"}], 
           ",", " ", 
           RowBox[{"\[Epsilon]", " ", "/", " ", "2"}], ",", " ", "0"}], 
          "]"}]}], "]"}]}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"i", ",", " ", "n"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"j", ",", " ", "n"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ComputeA2", "[", 
    RowBox[{"\[Delta]_", ",", " ", "\[Epsilon]_", ",", " ", "n_"}], "]"}], 
   " ", ":=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"i", " ", "==", " ", "j"}], ",", " ", 
       RowBox[{"\[Delta]", " ", "-", " ", 
        RowBox[{"i", "^", "2"}]}], ",", " ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Abs", "[", 
           RowBox[{"i", " ", "-", " ", "j"}], "]"}], " ", "==", " ", "1"}], 
         ",", " ", 
         RowBox[{"\[Epsilon]", " ", "/", " ", "2"}], ",", " ", "0"}], "]"}]}],
       "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"i", ",", " ", "n"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"j", ",", " ", "n"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ComputeA3", "[", 
    RowBox[{"\[Delta]_", ",", " ", "\[Epsilon]_", ",", " ", "n_"}], "]"}], 
   " ", ":=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"i", " ", "==", " ", "1"}], " ", "&&", " ", 
        RowBox[{"j", " ", "==", " ", "1"}]}], ",", " ", 
       RowBox[{"\[Delta]", " ", "-", " ", 
        RowBox[{"1", "/", "4"}], " ", "+", " ", 
        RowBox[{"\[Epsilon]", " ", "/", " ", "2"}]}], ",", " ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"i", " ", "==", " ", "j"}], ",", " ", 
         RowBox[{"\[Delta]", " ", "-", " ", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"2", " ", "*", " ", "i"}], " ", "-", " ", "1"}], ")"}], 
            "^", "2"}], " ", "/", " ", "4"}]}], ",", " ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"i", " ", "-", " ", "j"}], "]"}], " ", "==", " ", "1"}], 
           ",", " ", 
           RowBox[{"\[Epsilon]", " ", "/", " ", "2"}], ",", " ", "0"}], 
          "]"}]}], "]"}]}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"i", ",", " ", "n"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"j", ",", " ", "n"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ComputeA4", "[", 
    RowBox[{"\[Delta]_", ",", " ", "\[Epsilon]_", ",", " ", "n_"}], "]"}], 
   " ", ":=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"i", " ", "==", " ", "1"}], " ", "&&", " ", 
        RowBox[{"j", " ", "==", " ", "1"}]}], ",", " ", 
       RowBox[{"\[Delta]", " ", "-", " ", 
        RowBox[{"1", "/", "4"}], " ", "-", " ", 
        RowBox[{"\[Epsilon]", " ", "/", " ", "2"}]}], ",", " ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"i", " ", "==", " ", "j"}], ",", " ", 
         RowBox[{"\[Delta]", " ", "-", " ", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"2", " ", "*", " ", "i"}], " ", "-", " ", "1"}], ")"}], 
            "^", "2"}], " ", "/", " ", "4"}]}], ",", " ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"i", " ", "-", " ", "j"}], "]"}], " ", "==", " ", "1"}], 
           ",", " ", 
           RowBox[{"\[Epsilon]", " ", "/", " ", "2"}], ",", " ", "0"}], 
          "]"}]}], "]"}]}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"i", ",", " ", "n"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"j", ",", " ", "n"}], "}"}]}], "]"}]}], ";"}]}], "Code",
