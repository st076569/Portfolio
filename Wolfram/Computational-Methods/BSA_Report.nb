 RowBox[{
  RowBox[{
   RowBox[{"SolutionTor", "[", 
    RowBox[{"g_", ",", " ", "t_"}], "]"}], " ", ":=", " ", 
   RowBox[{"(", "\n", "\t", 
    RowBox[{
     RowBox[{"ConvertToGT", " ", "=", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\[Gamma]", " ", "->", " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", " ", "-", " ", "g"}], ")"}], " ", "/", " ", "2"}]}], 
        ",", " ", 
        RowBox[{"\[Sigma]", " ", "->", " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"g", " ", "+", " ", "1"}], ")"}], " ", "/", " ", "2"}]}], 
        ",", " ", 
        RowBox[{"\[Epsilon]", " ", "->", " ", "4"}]}], "}"}]}], ";", "\n", 
     "\t", 
     RowBox[{"SolLin", " ", "=", " ", 
      RowBox[{"NDSolveValue", "[", 
       RowBox[{
        RowBox[{"Union", "[", 
         RowBox[{
          RowBox[{"LinSys", " ", "/.", " ", "ConvertToGT"}], ",", " ", "X0"}],
          "]"}], ",", " ", "X", ",", " ", 
        RowBox[{"{", 
         RowBox[{"\[Tau]", ",", " ", "0", ",", " ", "t"}], "}"}]}], "]"}]}], 
     ";", "\n", "\t", 
     RowBox[{"r", " ", "=", " ", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"SolLin", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "^", "2"}], " ", "+", " ", 
        RowBox[{
         RowBox[{"SolLin", "[", 
          RowBox[{"[", "4", "]"}], "]"}], "^", "2"}]}], "]"}]}], ";", "\n", 
     "\t", "\n", "\t", 
     RowBox[{"p1", " ", "=", " ", 
      RowBox[{"ParametricPlot3D", "[", 
       RowBox[{
        RowBox[{"ToTor", "[", "SolLin", "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"\[Tau]", ",", " ", "0", ",", " ", "t"}], "}"}], ",", " ", 
        RowBox[{"PlotStyle", " ", "->", " ", 
         RowBox[{"{", "Blue", "}"}]}], ",", " ", 
        RowBox[{"PlotLegends", " ", "->", " ", 
         RowBox[{"Placed", "[", 
          RowBox[{
           RowBox[{"{", "\"\<Phase Space\>\"", "}"}], ",", " ", "Bottom"}], 
          "]"}]}], ",", " ", 
        RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], ";", "\n", "\t", 
     RowBox[{"p2", " ", "=", " ", 
      RowBox[{"ParametricPlot3D", "[", 
       RowBox[{
        RowBox[{"ToTor", "[", 
