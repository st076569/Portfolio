Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"PlotSolution", "[", 
    RowBox[{"\[Alpha]_", ",", " ", "\[Tau]_", ",", " ", "i_"}], "]"}], " ", ":=",
    " ", 
   RowBox[{"(", "\n", "\t", 
    RowBox[{
     RowBox[{"FX", " ", "=", " ", 
      RowBox[{"X", " ", "/.", " ", 
       RowBox[{
        RowBox[{"NDSolve", "[", 
         RowBox[{
          RowBox[{"Union", "[", 
           RowBox[{
            RowBox[{"Eq", " ", "/.", " ", 
             RowBox[{"a", " ", "->", " ", "\[Alpha]"}]}], ",", " ", 
            RowBox[{"Thread", "[", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"X", " ", "/.", " ", 
                RowBox[{"t", " ", "->", " ", "0"}]}], ")"}], " ", "==", " ", 
              RowBox[{"UnitVector", "[", 
               RowBox[{"3", ",", " ", "i"}], "]"}]}], "]"}]}], "]"}], ",", 
          " ", "X", ",", " ", 
          RowBox[{"{", 
           RowBox[{"t", ",", " ", "0", ",", " ", "\[Tau]"}], "}"}]}], "]"}], 
        "[", 
        RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\n", "\t", 
     RowBox[{"p1", " ", "=", " ", 
      RowBox[{"Plot", "[", 
       RowBox[{"FX", ",", " ", 
        RowBox[{"{", 
         RowBox[{"t", ",", " ", "0", ",", " ", "\[Tau]"}], "}"}], ",", " ", 
        RowBox[{"PlotRange", " ", "->", " ", "Full"}], ",", " ", 
        RowBox[{"PlotLegends", " ", "->", " ", 
         RowBox[{"Placed", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Subscript", "[", 
              RowBox[{"x", ",", " ", "1"}], "]"}], ",", " ", 
             RowBox[{"Subscript", "[", 
              RowBox[{"x", ",", " ", "2"}], "]"}], ",", " ", 
             RowBox[{"Subscript", "[", 
              RowBox[{"x", ",", " ", "3"}], "]"}]}], "}"}], ",", " ", 
           "Bottom"}], "]"}]}], ",", " ", "\n", "\t\t", 
        RowBox[{"AxesLabel", " ", "->", " ", 
         RowBox[{"{", 
          RowBox[{"t", ",", " ", 
           RowBox[{"x", "[", "t", "]"}]}], "}"}]}], ",", " ", 
        RowBox[{"GridLines", " ", "->", " ", "Automatic"}], ",", " ", 
        RowBox[{"PlotStyle", " ", "->", " ", 
         RowBox[{"{", 
          RowBox[{"Blue", ",", " ", "Red", ",", " ", 
           RowBox[{"Darker", "[", "Green", "]"}]}], "}"}]}], ",", " ", "\n", 
        "\t\t", 
        RowBox[{"PlotLabel", "->", 
         RowBox[{"Style", "[", 
          RowBox[{
           RowBox[{"Round", "[", 
            RowBox[{
             RowBox[{"NI", "[", "\[Alpha]", "]"}], ",", " ", "0.001"}], "]"}],
            ",", " ", "10"}], "]"}]}], ",", " ", 
        RowBox[{"ImageSize", "->", 
         RowBox[{"Scaled", "[", "0.9", "]"}]}]}], "]"}]}], ";", "\n", "\t", 
     RowBox[{"p2", " ", "=", " ", 
      RowBox[{"Show", "[", 
       RowBox[{
        RowBox[{"Plot", "[", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Max", "[", 
              RowBox[{"NIAbs", "[", "a", "]"}], "]"}], " ", "<", " ", "1"}], 
            ",", " ", "1", ",", " ", "0"}], "]"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"a", ",", " ", 
