Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"\[CapitalLambda](\[Mu]) = \"\>", "\[InvisibleSpace]", 
   RowBox[{
    RowBox[{
     SuperscriptBox["n", "2"], " ", 
     SuperscriptBox["\[Pi]", "2"]}], "+", 
    RowBox[{"2", " ", 
     SuperscriptBox["n", "2"], " ", 
     SuperscriptBox["\[Pi]", "2"], " ", "\[Mu]"}], "+", 
    RowBox[{
     SuperscriptBox["\[Pi]", "2"], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"3", " ", 
        SuperscriptBox["n", "2"]}], "+", 
       RowBox[{
        SuperscriptBox["n", "4"], " ", 
        SuperscriptBox["\[Pi]", "2"]}]}], ")"}], " ", 
     SuperscriptBox["\[Mu]", "2"]}]}]}],
  SequenceForm[
  "\[CapitalLambda](\[Mu]) = ", $CellContext`n^2 Pi^2 + 
   2 $CellContext`n^2 Pi^2 $CellContext`\[Mu] + 
   Pi^2 (3 $CellContext`n^2 + $CellContext`n^4 Pi^2) $CellContext`\[Mu]^2],
  Editable->False]], "Print",
