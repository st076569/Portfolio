        SuperscriptBox["n", "2"], " ", 
        SuperscriptBox["\[Pi]", "2"], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "2"}], "+", "x"}], ")"}], " ", "x", " ", 
        SuperscriptBox["\[Mu]", "2"]}]}], ")"}], " ", 
     RowBox[{"Sin", "[", 
      RowBox[{"n", " ", "\[Pi]", " ", "x"}], "]"}]}]}]}],
  SequenceForm[
  "X(\[Mu]) = ", 
   E^(-$CellContext`x/$CellContext`\[Mu]) $CellContext`n 
    Pi $CellContext`\[Mu] + $CellContext`n 
    Pi (-1 + $CellContext`x) $CellContext`\[Mu] 
    Cos[$CellContext`n Pi $CellContext`x] + 
   Rational[-1, 2] (-2 + 
     2 $CellContext`\[Mu] + $CellContext`n^2 
      Pi^2 (-2 + $CellContext`x) $CellContext`x $CellContext`\[Mu]^2) 
    Sin[$CellContext`n Pi $CellContext`x]],
