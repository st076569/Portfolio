Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"StabilityCondition", "[", "M_", "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"S", ",", " ", "J"}], "}"}], ",", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"S", ",", " ", "J"}], "}"}], " ", "=", " ", 
       RowBox[{"JordanDecomposition", "[", "M", "]"}]}], ";", "\n", "\t", 
      RowBox[{
       RowBox[{
        RowBox[{"Length", "[", 
         RowBox[{"Cases", "[", 
          RowBox[{
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{"Re", "[", 
                  RowBox[{"J", "[", 
                   RowBox[{"[", 
                    RowBox[{"i", ",", " ", "i"}], "]"}], "]"}], "]"}], " ", 
                 "<", " ", "0"}], " ", "||", " ", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"Re", "[", 
                    RowBox[{"J", "[", 
                    RowBox[{"[", 
                    RowBox[{"i", ",", " ", "i"}], "]"}], "]"}], "]"}], " ", "==",
                    " ", "0"}], " ", "&&", " ", 
                  RowBox[{
                   RowBox[{"Re", "[", 
                    RowBox[{"J", "[", 
                    RowBox[{"[", 
                    RowBox[{"i", ",", " ", 
                    RowBox[{"i", " ", "+", " ", "1"}]}], "]"}], "]"}], "]"}], 
                   " ", "==", " ", "0"}]}], ")"}]}], ",", " ", "1", ",", " ", 
               "0"}], "]"}], ",", " ", 
             RowBox[{"{", 
              RowBox[{"i", ",", " ", "1", ",", " ", 
               RowBox[{
                RowBox[{"Length", "[", "J", "]"}], " ", "-", " ", "1"}]}], 
              "}"}]}], "]"}], ",", " ", 
           RowBox[{"x_", " ", "/;", " ", 
            RowBox[{"x", " ", "==", " ", "0"}]}]}], "]"}], "]"}], " ", "==", 
        " ", "0"}], " ", "&&", " ", "\n", "\t", 
       RowBox[{
        RowBox[{"Re", "[", 
         RowBox[{"J", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"-", "1"}], ",", " ", 
            RowBox[{"-", "1"}]}], "]"}], "]"}], "]"}], " ", "<=", " ", 
        "0"}]}]}]}], "\n", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"CheckStability", "[", "M_", "]"}], " ", ":=", " ", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"StabilityCondition", "[", "M", "]"}], ",", " ", 
     RowBox[{"Print", "[", "\"\<Stable\>\"", "]"}], ",", " ", 
     RowBox[{"Print", "[", "\"\<Unstable\>\"", "]"}]}], "]"}]}], 
  ";"}]}], "Code",
 CellChangeTimes->{{3.9385366999721956`*^9, 3.9385367097045736`*^9}, {
