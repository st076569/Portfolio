Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"F", "[", 
    RowBox[{"\[Delta]_", ",", " ", "\[Epsilon]_", ",", " ", "n_"}], "]"}], 
   " ", ":=", " ", 
   RowBox[{
