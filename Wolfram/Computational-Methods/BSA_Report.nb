           RowBox[{"SolLin", "[", 
            RowBox[{"[", "1", "]"}], "]"}], ",", " ", 
           RowBox[{"r", " ", "*", " ", 
            RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", " ", 
           RowBox[{"SolLin", "[", 
            RowBox[{"[", "3", "]"}], "]"}], ",", " ", 
           RowBox[{"r", " ", "*", " ", 
            RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], "}"}], "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"\[Tau]", ",", " ", "0", ",", " ", "t"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"\[Theta]", ",", " ", "0", ",", " ", 
          RowBox[{"2", "*", "Pi"}]}], "}"}], ",", " ", 
        RowBox[{"PlotStyle", " ", "->", " ", 
         RowBox[{"{", 
          RowBox[{"Green", ",", " ", 
           RowBox[{"Opacity", "[", "0.3", "]"}]}], "}"}]}], ",", " ", "\n", 
        "\t\t", 
        RowBox[{"PlotPoints", " ", "->", " ", "10"}]}], "]"}]}], ";", "\n", 
     "\t", 
     RowBox[{"p3", " ", "=", " ", 
      RowBox[{"Plot", "[", 
       RowBox[{
        RowBox[{"SolLin", "[", 
         RowBox[{"[", "3", "]"}], "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"\[Tau]", ",", " ", "0", ",", " ", "t"}], "}"}], ",", " ", 
        RowBox[{"AxesLabel", " ", "->", " ", 
         RowBox[{"{", 
          RowBox[{"\[Tau]", ",", " ", 
           RowBox[{"\[CapitalAlpha]", "[", "\[Tau]", "]"}]}], "}"}]}], ",", 
        " ", 
        RowBox[{"GridLines", " ", "->", " ", "Automatic"}], ",", " ", 
        RowBox[{"AspectRatio", " ", "->", " ", 
         RowBox[{"1", "/", "2"}]}]}], "]"}]}], ";", "\n", "\t", 
